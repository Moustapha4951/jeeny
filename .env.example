# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jeeny?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-256-bits"
JWT_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# Firebase
FIREBASE_PROJECT_ID="jeeny-platform"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@jeeny-platform.iam.gserviceaccount.com"

# Agora
AGORA_APP_ID="your-agora-app-id"
AGORA_APP_CERTIFICATE="your-agora-app-certificate"

# Payment Gateways
BANKILY_API_URL="https://api.bankily.mr"
BANKILY_API_KEY="your-bankily-api-key"
BANKILY_MERCHANT_ID="your-merchant-id"
BANKILY_WEBHOOK_SECRET="your-webhook-secret"

SEDAD_API_URL="https://api.sedad.mr"
SEDAD_API_KEY="your-sedad-api-key"

MASRVI_API_URL="https://api.masrvi.mr"
MASRVI_API_KEY="your-masrvi-api-key"

# Google Maps
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# AWS S3 (Optional)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="jeeny-documents"

# App Configuration
PORT=3000
NODE_ENV="development"
API_URL="https://api.jeeny.mr"
FRONTEND_URL="https://admin.jeeny.mr"

# Encryption
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Sentry (Optional)
SENTRY_DSN="https://your-sentry-dsn"
