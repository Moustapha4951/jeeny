  AR
  FR
  EN
}

enum Gender {
  MALE
  FEMALE
}

enum DeviceType {
  ANDROID
  IOS
  WEB
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum EmployeeRole {
  DISPATCHER
  SUPPORT
  OPERATIONS
  FINANCE
  CALL_CENTER
  DRIVER_MANAGEMENT
}

